# Application
NODE_ENV=development
PORT=3001

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/travelsathi?schema=public

# Firebase Authentication
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@appspot.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT (Optional: if you want custom JWT signing beyond Firebase)
JWT_SECRET=your-super-secret-key-min-32-characters-long

# External AI Service (for Phase 1 simple chatbot)
AI_SERVICE_URL=http://localhost:5000
AI_SERVICE_KEY=your-ai-service-api-key

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19000
