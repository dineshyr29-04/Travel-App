// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// MODELS
// ========================

/// User model - stores user info from Firebase Auth
model User {
  id        String     @id @default(cuid())
  firebaseUid String   @unique
  email     String     @unique
  name      String
  phone     String?
  avatar    String?
  bio       String?
  city      String?
  country   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  trips     Trip[]
  localites Localite[]

  @@map("users")
}

/// Trip model - tourism trips/itineraries
model Trip {
  id          String     @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  budget      Float?
  city        String
  country     String
  activities  String[]   @default([])
  status      String     @default("draft") // draft, published, archived
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relation
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([city, country])
  @@map("trips")
}

/// Localite model - local guides/experts
model Localite {
  id          String     @id @default(cuid())
  city        String
  country     String
  expertise   String[]   @default([]) // e.g., ["trekking", "food", "urban"]
  bio         String
  languages   String[]   @default([])
  rating      Float      @default(0)
  reviews     Int        @default(0)
  verificationStatus String @default("pending") // pending, verified
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relation
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city, country])
  @@map("localites")
}
