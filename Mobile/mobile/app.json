
{
  "expo": {
    "name": "TravelSathi",
    "slug": "travelsathi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "iOS": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.travelsathi.app"
    },
    "android": {
      "package": "com.travelsathi.app",
      "versionCode": 1
    },
    "web": {},
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
