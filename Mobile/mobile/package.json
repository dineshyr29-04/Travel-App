{
  "name": "travelsathi-mobile",
  "version": "0.1.0",
  "description": "Production-ready React Native tourism app using Expo",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@reduxjs/toolkit": "^1.9.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "expo": "^55.0.11",
    "expo-status-bar": "^1.11.0",
    "react": "^18.2.0",
    "react-native": "^0.84.1",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.29.0",
    "react-redux": "^8.1.0",
    "redux-persist": "^6.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@react-native-community/cli": "^13.0.0",
    "@react-native/metro-config": "^0.84.0",
    "@testing-library/react-native": "^12.1.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "expo-build-properties": "^55.0.11",
    "expo-font": "^11.7.0",
    "expo-splash-screen": "^0.26.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "react-native-dotenv": "^3.3.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "TravelSathi Team",
  "license": "MIT",
  "keywords": [
    "react-native",
    "expo",
    "travel",
    "tourism",
    "redux"
  ]
}
